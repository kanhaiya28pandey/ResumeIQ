# MongoDB connection string
MONGO_URI=mongodb://localhost:27017
DB_NAME=resume_matcher

# JWT settings
JWT_SECRET=change_this_to_something_random_and_long
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Email settings (used for sending OTP for forgot password)
# If using Gmail, you need to create an "App Password" from your Google account,
# normal gmail password won't work here because of security restrictions.
EMAIL_ADDRESS=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
